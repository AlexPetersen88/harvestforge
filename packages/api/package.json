{
  "name": "@harvestforge/api",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "migrate": "node-pg-migrate up --database-url-var DATABASE_URL --migration-file-language ts --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migration-file-language ts --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language ts --migrations-dir migrations",
    "seed": "tsx src/seeds/run.ts",
    "db:reset": "tsx src/seeds/reset.ts"
  },
  "dependencies": {
    "@harvestforge/shared": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "pg": "^8.13.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-kit": "^0.30.0",
    "ioredis": "^5.4.0",
    "zod": "^3.23.0",
    "node-pg-migrate": "^7.7.0",
    "pino": "^9.5.0",
    "pino-pretty": "^12.0.0",
    "undici": "^7.0.0",
    "cron": "^3.2.0",
    "geojson": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/geojson": "^7946.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "eslint": "^9.14.0",
    "@faker-js/faker": "^9.2.0"
  }
}
