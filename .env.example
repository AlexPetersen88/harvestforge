# ─── HarvestForge Environment ──────────────────────────────
# Copy this to .env and fill in your values
# ───────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://harvestforge:hf_dev_password_2026@localhost:5432/harvestforge

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=dev-jwt-secret-change-in-production

# ─── Solver ──────────────────────────────────────────────
SOLVER_URL=http://localhost:8001

# ─── John Deere OAuth ────────────────────────────────────
# Register at https://developer.deere.com
JD_CLIENT_ID=
JD_CLIENT_SECRET=
JD_REDIRECT_URI=http://localhost:3001/v1/auth/jd/callback
JD_SCOPES=ag1 ag2 ag3 eq1 eq2

# ─── Mapbox ──────────────────────────────────────────────
# Get token at https://account.mapbox.com
MAPBOX_TOKEN=

# ─── Weather API ─────────────────────────────────────────
# Tomorrow.io or OpenWeather
WEATHER_API_KEY=
WEATHER_PROVIDER=tomorrow_io

# ─── Auth0 ───────────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.harvestforge.io

# ─── AWS S3 (media storage for voice notes, photos) ─────
AWS_REGION=us-east-1
AWS_S3_BUCKET=harvestforge-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/v1
VITE_WS_URL=ws://localhost:3001/ws
VITE_MAPBOX_TOKEN=
